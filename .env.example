# =====================================================
#  Pinnacle — required environment variables
#  COPY THIS FILE TO .env AND FILL IN PRIVATELY.
#  NEVER COMMIT .env TO SOURCE CONTROL.
# =====================================================

# Upstream odds API (server-side only — never exposed client-side)
ODDS_API_KEY=

# Allowed origins (comma-separated, exact match, no wildcards)
ALLOWED_ORIGINS=https://pinnacle.app,https://www.pinnacle.app

# Session signing key — 64 hex chars (32 bytes). Rotate quarterly.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Bcrypt cost factor for password hashing (12 = ~250ms per hash)
BCRYPT_COST=12

# Rate limit storage (Upstash Redis recommended for multi-instance)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe (server-side)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public-side Stripe key (this one IS exposed to client; restricted by Stripe)
NEXT_PUBLIC_STRIPE_KEY=

# Anthropic API key for AI insights panel (server-side only)
ANTHROPIC_API_KEY=
